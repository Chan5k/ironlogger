# Optional. For production builds (Vercel etc.), set to your API origin — no path, no trailing slash.
# Example: https://ironlog-api.onrender.com
# Also used to ping /api/health on a timer so a cold Render dyno stays warm (see ApiKeepAlive.jsx).
# During `npm run dev`, VITE_API_URL is ignored so /api always proxies to localhost:5000 (avoids CORS
# when .env.local was copied from production).
# VITE_API_URL=

# Optional. Keep-alive interval in ms (min ~10s). Default 300000 (5 minutes).
# VITE_API_KEEPALIVE_MS=300000

# GitHub Pages project site only: path segment matching the repo name, with slashes.
# Example repo "ironlog" → https://user.github.io/ironlog/  →  VITE_BASE_PATH=/ironlog/
# Omit or use / for username.github.io user sites.
# VITE_BASE_PATH=

# Must match server VAPID_PUBLIC_KEY (same pair as VAPID_PRIVATE_KEY). Used for “push when app is closed”.
# VITE_VAPID_PUBLIC_KEY=
