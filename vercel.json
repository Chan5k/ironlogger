{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build --prefix client",
  "installCommand": "npm install --prefix client",
  "outputDirectory": "client/dist",
  "cleanUrls": false,
  "trailingSlash": false,
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
