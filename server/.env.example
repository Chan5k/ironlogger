PORT=5000
# Set to 1 if the API sits behind a reverse proxy in dev and rate limits should use X-Forwarded-For.
# TRUST_PROXY=1
MONGODB_URI=mongodb://127.0.0.1:27017/gym-tracker
JWT_SECRET=change-this-to-a-long-random-string-in-production
# Access token lifetime (jsonwebtoken string, e.g. 90d, 365d). Default 90d.
# JWT_EXPIRES_IN=90d
# One origin, or several comma-separated (Vercel prod + preview + local)
CLIENT_URL=http://localhost:5173

# Transactional email (verification). Without SMTP_HOST, links are only logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="IronLog <noreply@yourdomain.com>"

# Dev / automated tests: create accounts already verified (do not use in production).
# SKIP_EMAIL_VERIFICATION=1

# Hevy plan import (POST /import/hevy-plan) calls Hevy’s public web API. Default matches their web app;
# set this if they rotate the key and imports fail with 502.
# HEVY_WEB_API_KEY=shelobs_hevy_web

# Optional. Comma-separated emails that get admin dashboard + /api/admin (without DB isAdmin flag).
# ADMIN_EMAILS=you@example.com

# Web Push (optional). Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# Shared secret for POST /api/cron/push-reminders (call every minute from a scheduler).
# CRON_SECRET=
