PORT=5000
# Set to 1 if the API sits behind a reverse proxy in dev and rate limits should use X-Forwarded-For.
# TRUST_PROXY=1
MONGODB_URI=mongodb://127.0.0.1:27017/gym-tracker
JWT_SECRET=change-this-to-a-long-random-string-in-production
# One origin, or several comma-separated (Vercel prod + preview + local)
CLIENT_URL=http://localhost:5173

# Optional. Comma-separated emails that get admin dashboard + /api/admin (without DB isAdmin flag).
# ADMIN_EMAILS=you@example.com

# Web Push (optional). Generate: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:you@example.com
# Shared secret for POST /api/cron/push-reminders (call every minute from a scheduler).
# CRON_SECRET=
